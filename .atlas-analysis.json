  "keyFeatures": [
    "Real-time sensor monitoring with 100Hz data ingestion",
    "Dual Isolation Forest anomaly detection (99.6% F1 score)",
    "Cumulative Degradation Index with monotonic health tracking",
    "ML-powered explainability with human-readable insights",
    "Role-specialized reporting (Executive PDF, Analyst Excel, Industrial Certificate)",
    "React dashboard with real-time visualization and fault injection controls",
    "InfluxDB Cloud time-series persistence with restart-safe state hydration",
    "Docker and systemd deployment options"
  ],
  "publicApiSurface": [
    "POST /ingest - Ingest sensor data with validation",
    "GET /health - System health check",
    "GET /ping - Keep-alive heartbeat",
    "POST /system/calibrate - Start baseline calibration",
    "POST /system/inject-fault - Inject fault with severity control",
    "POST /system/purge - Deep system reset",
    "GET /system/state - Get current system state",
    "GET /integration/health-status - Get asset health assessment",
    "GET /integration/sensor-history - Query time-series data",
    "POST /operator/logs - Create maintenance event log",
    "GET /operator/logs - Retrieve operator logs",
    "GET /reports/executive-pdf - Generate executive summary",
    "GET /reports/analyst-excel - Generate multi-sheet workbook",
    "GET /reports/industrial-pdf - Generate 5-page technical report",
    "POST /sandbox/what-if - Simulate fault scenarios"
  ]
